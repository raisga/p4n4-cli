# ==============================================================================
# Mosquitto Password File — Example
# ==============================================================================
# DO NOT use this file directly. Generate a real password file:
#
#   docker run --rm -it eclipse-mosquitto:2 mosquitto_passwd -c /dev/stdout <username>
#
# Then copy the output line here and save as 'passwd' (no .example extension).
# Reference it in mosquitto.conf:
#
#   allow_anonymous false
#   password_file /mosquitto/config/passwd
#
# Mount the passwd file in docker-compose.yml:
#   - ./config/mosquitto/passwd:/mosquitto/config/passwd:ro
#
# Format: username:hashed_password  (generated by mosquitto_passwd)
# ==============================================================================

# node-red:<hashed>
# grafana:<hashed>
# iot-device-001:<hashed>
